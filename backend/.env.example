# Database
DATABASE_URL=sqlite:///agriguard.db

# AI Provider selection: groq | gemini | ollama
# Groq is recommended (free tier, no local GPU required)
AI_PROVIDER=groq

# --- FREE Cloud API Keys ---
# Groq API key (FREE tier) - get at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API key (FREE tier) - get at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# --- Optional / Not Required ---
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# Ollama Configuration (only if running Ollama locally)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_VISION=llava
OLLAMA_MODEL_LLM=mistral

# Weather API (free, no key required)
WEATHER_API_BASE=https://api.open-meteo.com/v1

# Server
DEBUG=True
PORT=8000
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]
